# ── Telegram ──────────────────────────────────────────────
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# The username or ID of the channel to monitor (e.g. @trucklistings or -1001234567890)
TELEGRAM_CHANNEL=
# Optional: The username or ID of a second Telegram channel to post the AI-rewritten listings to
TARGET_TELEGRAM_CHANNEL=

# ── Anthropic ─────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Facebook ──────────────────────────────────────────────
# Long-lived Page Access Token from Meta Developer Console
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# ── Your Contact Details (appended to every post) ─────────
WHATSAPP_NUMBER=+2348000000000
TELEGRAM_USERNAME=@yourusername

# ── Behaviour ─────────────────────────────────────────────
# Seconds to wait before processing a media group (collect all photos)
MEDIA_GROUP_BUFFER_SECONDS=3
